ANTHROPIC_API_KEY=sk-ant-your-key-here

# URL of the deployed Express proxy. Used by the frontend to construct the API endpoint.
# Leave blank in local dev — the Vite dev proxy handles /api/* automatically.
VITE_API_URL=

# Comma-separated list of allowed CORS origins for the proxy server.
# In production set this to your deployed frontend URL (e.g. https://tony.dinh.nz).
# Defaults to localhost in development if not set.
ALLOWED_ORIGINS=https://your-frontend-domain.com

# AWS — only needed for local dev proxy (Lambda uses its IAM role automatically)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-2

# DynamoDB table name (must match what you created in the AWS Console)
VISITORS_TABLE=alfred-visitors
